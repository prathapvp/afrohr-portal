# Copy this file to .env and fill in real values (never commit .env)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/afrohr
DATABASE_USERNAME=afrohr
DATABASE_PASSWORD=secret

# ── JPA ───────────────────────────────────────────────────────────────────────
DDL_AUTO=update          # use 'validate' or 'none' in production
SHOW_SQL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-256-bit-base64-encoded-secret
JWT_EXPIRATION_MS=86400000   # 24 h in milliseconds

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
